{
  "info": {
    "name": "Zuri Adventures - Run Order",
    "_postman_id": "3f2e8d2a-2f9d-4d90-92ac-f1336f3191db",
    "description": "Recommended request sequence for local API testing. Run top to bottom.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "item": [
    {
      "name": "1) Health - GET /health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "2) API shell - GET /api/v1/",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1"]
        }
      },
      "response": []
    },
    {
      "name": "3) Auth login - POST /api/v1/auth/login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.accessToken) pm.environment.set('accessToken', json.accessToken);",
              "pm.test('login status 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "4) Admin packages create - POST /api/v1/admin/packages",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"slug\": \"prison-island-nakupenda\",\n  \"name\": \"Prison Island & Nakupenda Sandbank Trip\",\n  \"duration\": \"8 hours\",\n  \"tourType\": \"Full Day\",\n  \"maxPeople\": 30,\n  \"minAge\": 10,\n  \"schedulingMode\": \"FIXED_DEPARTURES\",\n  \"featured\": 1,\n  \"publish\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/packages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "admin", "packages"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.id) pm.environment.set('packageId', json.id);"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "5) Admin adventures create - POST /api/v1/admin/adventures",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"slug\": \"stone-town-day-adventure\",\n  \"title\": \"Stone Town Day Adventure\",\n  \"subtitle\": \"Historic city & coast\",\n  \"description\": \"Explore Stone Town and nearby island highlights.\",\n  \"publish\": 1,\n  \"relatedPackageId\": {{packageId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/adventures",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "admin", "adventures"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.id) pm.environment.set('adventureId', json.id);"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "6) Public packages list - GET /api/v1/packages",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/packages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "packages"]
        }
      },
      "response": []
    },
    {
      "name": "7) Public package detail - GET /api/v1/packages/{{packageSlug}}",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/packages/{{packageSlug}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "packages", "{{packageSlug}}"]
        }
      },
      "response": []
    },
    {
      "name": "8) Public adventures list - GET /api/v1/adventures",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/adventures",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "adventures"]
        }
      },
      "response": []
    },
    {
      "name": "9) Public adventure detail - GET /api/v1/adventures/{{adventureSlug}}",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/adventures/{{adventureSlug}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "adventures", "{{adventureSlug}}"]
        }
      },
      "response": []
    },
    {
      "name": "10) Auth logout - POST /api/v1/auth/logout",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": ["api", "v1", "auth", "logout"]
        }
      },
      "response": []
    }
  ],
