# Copy to `server/.env` and fill in real values locally.

# Server
PORT=3001
NODE_ENV=development

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=zuri_adventures

# JWT (admin)
JWT_ACCESS_SECRET=change_this_secret
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token (cookie)
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_EXPIRES_IN_DAYS=14
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=strict

# CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Optional: create first admin automatically (for local only)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_this_password

# SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=your_email@example.com
ENQUIRY_STAFF_EMAILS=your_email@example.com

# Public site origin (canonical URLs in sitemap.xml + robots.txt). Use your live domain in production.
SITE_URL=http://localhost:5173